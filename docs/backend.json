
{
  "entities": {
    "Course": {
      "title": "Course",
      "description": "A dynamic learning program offered by The Finance School",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "oldPrice": { "type": "number" },
        "imageUrl": { "type": "string" },
        "instamojoLink": { "type": "string" },
        "features": {
          "type": "array",
          "items": { "type": "string" }
        },
        "order": { "type": "number" }
      },
      "required": ["title", "description", "price", "imageUrl", "instamojoLink"]
    },
    "Book": {
      "title": "Book",
      "description": "Financial educational books and study materials",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "oldPrice": { "type": "number" },
        "imageUrl": { "type": "string" },
        "instamojoLink": { "type": "string" },
        "features": {
          "type": "array",
          "items": { "type": "string" }
        },
        "order": { "type": "number" }
      },
      "required": ["title", "description", "price", "imageUrl", "instamojoLink"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A scheduled consultation session",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "date": { "type": "string" },
        "slot": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "failed"] },
        "amount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "email", "date", "slot"]
    },
    "HomepageSettings": {
      "title": "Homepage Settings",
      "description": "Hero section content, social links, and consultation text configuration",
      "type": "object",
      "properties": {
        "heroBadge": { "type": "string" },
        "heroHeadline": { "type": "string" },
        "heroSubheadline": { "type": "string" },
        "heroDescription": { "type": "string" },
        "cta1Text": { "type": "string" },
        "cta1Link": { "type": "string" },
        "cta2Text": { "type": "string" },
        "cta2Link": { "type": "string" },
        "instagramUrl": { "type": "string" },
        "youtubeUrl": { "type": "string" },
        "telegramUrl": { "type": "string" },
        "facebookUrl": { "type": "string" },
        "consultationHeadline": { "type": "string" },
        "consultationDescription": { "type": "string" },
        "consultationF1Title": { "type": "string" },
        "consultationF1Desc": { "type": "string" },
        "consultationF2Title": { "type": "string" },
        "consultationF2Desc": { "type": "string" },
        "consultationF3Title": { "type": "string" },
        "consultationF3Desc": { "type": "string" },
        "consultationCardTitle": { "type": "string" },
        "consultationCardDesc": { "type": "string" },
        "consultationPaymentLink": { "type": "string" },
        "aboutHeadline": { "type": "string" },
        "aboutDescription": { "type": "string" },
        "aboutPhilosophy1Title": { "type": "string" },
        "aboutPhilosophy1Desc": { "type": "string" },
        "aboutPhilosophy2Title": { "type": "string" },
        "aboutPhilosophy2Desc": { "type": "string" },
        "aboutPhilosophy3Title": { "type": "string" },
        "aboutPhilosophy3Desc": { "type": "string" },
        "aboutStat1Value": { "type": "number" },
        "aboutStat2Value": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "rules": "firestore.rules",
    "collections": {
      "/courses/{courseId}": {
        "schema": "Course",
        "description": "List of courses managed by the admin"
      },
      "/books/{bookId}": {
        "schema": "Book",
        "description": "List of books managed by the admin"
      },
      "/bookings/{bookingId}": {
        "schema": "Booking",
        "description": "Customer consultation bookings"
      },
      "/settings/homepage": {
        "schema": "HomepageSettings",
        "description": "Configuration for the homepage hero section and social links"
      }
    }
  }
}

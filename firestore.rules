rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if the user is one of the authorized admins
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email.lower() == 'thefinanceschoolonline@gmail.com' ||
        request.auth.token.email.lower() == 'venkateshchop14@gmail.com'
      );
    }

    // Courses: Publicly readable, admin writable
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Books: Publicly readable, admin writable
    match /books/{bookId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Bookings: Admin can see all, anyone can create, only admin can update/delete
    match /bookings/{bookingId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Settings (Homepage content): Publicly readable, admin writable
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}